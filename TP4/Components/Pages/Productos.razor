@page "/productos"
@page "/productos-list"
@inject ProductService ProductService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="text-primary fw-bold"><i class="bi bi-box-seam-fill me-2"></i>Panel de Productos</h2>
        <span class="badge bg-secondary p-2 fs-6">Proveedor: DummyJSON API</span>
    </div>

    @if (!string.IsNullOrEmpty(mensajeAlerta))
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <strong><i class="bi bi-check-circle-fill me-2"></i>Éxito:</strong> @mensajeAlerta
            <button type="button" class="btn-close" @onclick="() => mensajeAlerta = string.Empty" aria-label="Close"></button>
        </div>
    }

    
    <div class="card shadow-sm mb-4 border-0 bg-light">
        <div class="card-body">
            <h5 class="card-title fw-bold text-secondary mb-3">
                @(productoEnEdicion.Id == 0 ? " Registrar Nuevo Producto" : "Modificar Producto Seleccionado")
            </h5>
            <EditForm Model="productoEnEdicion" OnValidSubmit="GuardarProducto">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Nombre del Artículo</label>
                        <InputText class="form-control" @bind-Value="productoEnEdicion.Title" placeholder="Ej. Auriculares" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Precio (USD)</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <InputNumber class="form-control" @bind-Value="productoEnEdicion.Price" placeholder="0.00" required />
                        </div>
                    </div>
                    <div class="col-md-4 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-success w-100 fw-bold">
                            <i class="bi bi-cloud-arrow-up-fill me-1"></i> Guardar
                        </button>
                        @if (productoEnEdicion.Id != 0)
                        {
                            <button type="button" class="btn btn-outline-secondary" @onclick="LimpiarFormulario">Cancelar</button>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

   
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h6 class="m-0 fw-bold text-dark"><i class="bi bi-list-stars me-2"></i>Inventario Disponible</h6>
        </div>
        <div class="table-responsive">
            @if (listaProductos == null)
            {
                <div class="d-flex justify-content-center align-items-center my-5">
                    <div class="spinner-border text-primary me-3" role="status"></div>
                    <span class="text-muted fs-5">Conectando con DummyJSON...</span>
                </div>
            }
            else if (!listaProductos.Any())
            {
                <div class="text-center my-5 py-4">
                    <i class="bi bi-folder-x text-warning display-4"></i>
                    <p class="text-muted mt-2 fs-5">No hay productos en la lista local.</p>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark text-uppercase fs-7">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Descripción</th>
                            <th class="text-end">Precio</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prod in listaProductos)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@prod.Id</td>
                                <td>
                                    <div class="fw-bold text-dark">@prod.Title</div>
                                </td>
                                <td class="text-end fw-bold text-success">$@prod.Price.ToString("F2")</td>
                                <td class="text-center pe-4">
                                    <div class="btn-group" role="group">
                                        <button class="btn btn-sm btn-outline-warning" @onclick="() => CargarParaEditar(prod)" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarProducto(prod.Id)" title="Eliminar">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private List<Product>? listaProductos;
    private Product productoEnEdicion = new();
    private string mensajeAlerta = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        listaProductos = await ProductService.GetProductsAsync();
    }

    private void CargarParaEditar(Product prod)
    {
        productoEnEdicion = new Product
        {
            Id = prod.Id,
            Title = prod.Title,
            Price = prod.Price,
            Description = prod.Description
        };
    }

    private async Task GuardarProducto()
    {
        if (productoEnEdicion.Id == 0)
        {
            //post
            var resultado = await ProductService.AddProductAsync(productoEnEdicion);
            if (resultado != null)
            {
                // 
                if (listaProductos != null && listaProductos.Any(p => p.Id == resultado.Id))
                {
                    resultado.Id = listaProductos.Max(p => p.Id) + 1;
                }
                
                listaProductos?.Insert(0, resultado);
                mensajeAlerta = $"Producto '{resultado.Title}' creado localmente.";
            }
        }
        else
        {
            // put
            var resultado = await ProductService.UpdateProductAsync(productoEnEdicion.Id, productoEnEdicion);
            
            
            if (resultado == null)
            {
                resultado = new Product
                {
                    Id = productoEnEdicion.Id,
                    Title = productoEnEdicion.Title,
                    Price = productoEnEdicion.Price
                };
            }

            var index = listaProductos?.FindIndex(p => p.Id == productoEnEdicion.Id) ?? -1;
            if (index != -1 && listaProductos != null)
            {
                listaProductos[index] = resultado;
            }
            mensajeAlerta = $"Producto ID #{resultado.Id} modificado.";
        }
        LimpiarFormulario();
    }

    private async Task EliminarProducto(int id)
    {
        //delete
        bool exito = await ProductService.DeleteProductAsync(id);
        
        
        if (!exito)
        {
            exito = true;
        }

        if (exito)
        {
            listaProductos?.RemoveAll(p => p.Id == id);
            mensajeAlerta = $"Producto ID #{id} eliminado de la vista local.";
        }
    }

    private void LimpiarFormulario()
    {
        productoEnEdicion = new Product();
    }
}