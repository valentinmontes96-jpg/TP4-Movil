@page "/NotFound"

<PageTitle>Página no encontrada</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 p-5 bg-white">
                <i class="bi bi-exclamation-triangle-fill display-1 text-warning mb-4"></i>
                
                <h1 class="display-3 fw-bold text-dark mb-2">404</h1>
                <h3 class="fw-semibold text-secondary mb-4">¡Ups! Ruta desconocida</h3>
                
                <p class="lead text-muted mb-5">
                     La página que intentas buscar no existe, fue movida o escribiste mal la dirección.
                </p>
                
                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <a href="/" class="btn btn-primary btn-lg px-4 shadow-sm fw-bold">
                        <i class="bi bi-house-door-fill me-2"></i> Volver al Inicio
                    </a>
                    <a href="productos" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">
                        <i class="bi bi-box-seam me-2"></i> Ir a Productos
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>